{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scout",
  "version": "0.2.1",
  "identifier": "com.bloxystudios.scout",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "notch",
        "title": "Scout",
        "width": 132,
        "height": 36,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "capabilities": [
        "default",
        "preferences"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
